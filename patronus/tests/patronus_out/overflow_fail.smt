(check-sat-assuming ((and  true (=  count@1 #b10)) (and  true (=  (= ((_ extract 1 1)  count@1) #b1) false)) ))
(check-sat-assuming ((and  true (=  count@1 #b10)) (and  true (=  (= ((_ extract 1 1)  count@2) #b1) false)) ))
(check-sat-assuming ((and  true (or  false (not  (=  (= ((_ extract 1 1)  count@1) #b1) false)))) (or  false (and  true (not  (not  (=  count@1 #b00))))) ))
(check-sat-assuming ((and  true (or  false (not  (=  (= ((_ extract 1 1)  count@1) #b1) false)))) (and  true (=  (= ((_ extract 1 1)  count@2) #b1) false)) ))
(check-sat-assuming (true (or  false (and  true (not  (not  (=  count@1 #b00))))) ))
(get-value (count@1))
(get-value (count@1))
(get-value (clk@1))
(check-sat-assuming ((and  true (or  false (not  (=  (= ((_ extract 1 1)  count@1) #b1) false)))) (and  (and  true (=  (= ((_ extract 0 0)  count@2) #b1) false)) (=  (= ((_ extract 1 1)  count@2) #b1) false)) (or  (or  false (not  (=  (= ((_ extract 0 0)  count@1) #b1) false))) (not  (=  (= ((_ extract 1 1)  count@1) #b1) false))) ))
(get-value (count@1))

(set-option :incremental true)
(set-option :produce-models true)
(set-logic QF_ABV)
(declare-const count@1 (_ BitVec 2))
(declare-const clk@1 Bool)
(define-fun |Overflow.sv:9.9-9.31@1| () Bool (and  true (not  (not  (=  count@1 #b00)))))
(define-fun count@2 () (_ BitVec 2) (bvadd  count@1 (ite  true #b01 #b00)))
(declare-const clk@2 Bool)
(define-fun |Overflow.sv:9.9-9.31@2| () Bool (and  true (not  (not  (=  count@2 #b00)))))
(check-sat-assuming ((and  true (=  count@1 #b10)) (or  false (and  true (not  (not  (=  count@1 #b00))))) ))
(check-sat-assuming (true (or  false (and  true (not  (not  (=  count@1 #b00))))) ))

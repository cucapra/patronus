(set-option :incremental true)
(set-option :produce-models true)
(set-logic QF_ABV)
(declare-const _bad_0@1 Bool)
(declare-const trigger@1 Bool)
(define-fun _bad_0@2 () Bool trigger@1)
(declare-const trigger@2 Bool)
(declare-const act_0 Bool)
(assert (=>  act_0 (and  true (=  _bad_0@1 false))))
(check-sat-assuming (act_0 (or  false _bad_0@1) ))
(check-sat-assuming (act_0 (or  false _bad_0@2) ))
(get-value (_bad_0@1))
(check-sat-assuming (act_0 (and  true (=  _bad_0@1 false)) ))
(get-value (_bad_0@1))
(get-value (trigger@1))
(exit)
